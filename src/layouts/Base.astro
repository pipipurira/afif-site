---
const { title } = Astro.props
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} — Afif Musyaffa</title>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">afif</a>
      <div class="nav-links">
        <a href="/work">Work</a>
        <a href="/writing">Writing</a>
        <a href="/about">About</a>
      </div>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a0a0a;
    --surface: #141414;
    --text: #f0ece4;
    --muted: #888780;
    --accent: #000072;
    --border: rgba(240, 236, 228, 0.1);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.7;
  }
  h1, h2, h3 { font-family: Georgia, serif; font-weight: 400; }
  a { color: inherit; text-decoration: none; }
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }
  .logo { font-size: 13px; font-weight: 500; }
  .nav-links { display: flex; gap: 1.5rem; }
  .nav-links a { font-size: 12px; color: var(--muted); }
  .nav-links a:hover { color: var(--text); }
</style>