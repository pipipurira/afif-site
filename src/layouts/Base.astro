---
const { title } = Astro.props
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} - making content content </title>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">inside afif</a>
      <div class="nav-links">
        <a href="/work">Work</a>
        <a href="/writing">Writing</a>
        <a href="/about">About</a>
      </div>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* --- The Soft Noise Palette --- */
    --bg: #EAE6DF; /* Latar utama: Krem pucat / Dusty Stone yang sangat menenangkan mata */
    --surface: #DFDAD1; /* Latar sekunder (untuk tag/kategori): Sedikit lebih gelap dari bg */
    --text: #111111; /* Teks: Hitam tinta pekat, menabrak tajam latarnya */
    --muted: #6B6B6B; /* Teks pelengkap & menu navigasi: Abu-abu editorial */
    
    /* Aksen kreatif untuk link/hover, silakan bereksperimen! */
    --accent: #FF3B00; /* Oranye kemerahan (Pop/Neon) yang playful */
    
    /* Kunci Brutalism-nya ada di sini: */
    --border: #111111; /* Garis pembatas berubah jadi hitam pekat dan solid */
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.7;
  }
  h1, h2, h3 { font-family: Georgia, serif; font-weight: 400; }
  a { color: inherit; text-decoration: none; }
  .logo {
    font-family: 'Helvetica Neue', Arial, sans-serif; 
    font-size: 25px; 
    font-style: italic; 
    font-weight: 900; /* Paling tebal */
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.05em; /* Sangat dirapatkan */
    word-spacing: 0.15em;
  }
  /* --- Navigasi --- */
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem; 
    align-items: center;
  }

  .nav-links a {
    font-family: 'Courier New', Courier, monospace; 
    font-size: 12px; 
    text-transform: uppercase; 
    letter-spacing: 0.1em; 
    color: var(--muted); 
    border-bottom: 1px solid transparent; 
    transition: all 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--text); 
    border-bottom: 1px solid var(--text); 
  }
</style>