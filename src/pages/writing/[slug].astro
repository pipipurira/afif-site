---
import Base from '../../layouts/Base.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('writing')
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
---

<Base title={post.data.title}>
  <article>
    {post.data.cover && (
      <div class="cover">
        <img src={post.data.cover} alt={post.data.title} />
      </div>
    )}
    <div class="content">
      <div class="meta">
        <span class="category">{post.data.category}</span>
        <span class="date">
          {post.data.date.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
        </span>
      </div>
      <h1>{post.data.title}</h1>
      <div class="body">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  article { max-width: 720px; margin: 0 auto; padding: 3rem 2rem; }

  .cover {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  .cover img { width: 100%; height: 100%; object-fit: cover; }

  .meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .category {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .08em;
    text-transform: uppercase;
    border: 0.5px solid var(--border);
    padding: 3px 10px;
  }
  .date { font-size: 12px; color: var(--muted); align-self: center; }

  h1 {
    font-family: Georgia, serif;
    font-size: 36px;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  .body { font-family: Georgia, serif; font-size: 18px; line-height: 1.8; color: var(--text); }
  .body p { margin-bottom: 1.5rem; }
  .body h2 { font-size: 24px; margin: 2rem 0 1rem; }
  .body h3 { font-size: 20px; margin: 2rem 0 1rem; }
</style>