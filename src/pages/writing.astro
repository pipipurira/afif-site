---
import Base from '../layouts/Base.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)

const categories = ['Semua', 'Opini', 'Behind the Scene', 'Inspirasi']
---

<Base title="Writing">
  <main>
    <div class="page-header">
      <h2>Writing</h2>
      <p>{posts.length} tulisan</p>
    </div>

    <div class="categories">
      {categories.map((cat, i) => (
        <span class={`cat ${i === 0 ? 'active' : ''}`}>{cat}</span>
      ))}
    </div>

    <div class="post-list">
  {posts.map((post, index) => (
    <a href={`/writing/${post.id}`} class="post-item">
      <span class="post-number">{String(index + 1).padStart(2, '0')}</span>
      
      <div class="post-info">
        <h3 class="post-title">{post.data.title}</h3>
        
        {post.data.description && <p class="post-excerpt">{post.data.description}</p>}
        
        <p class="post-meta">
          <span>{post.data.category}</span>
          <span class="separator">/</span>
          <span>{post.data.date.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </p>
      </div>

      <div class="post-cover-container">
        {post.data.cover && (
          <img 
            src={post.data.cover} 
            alt={`Cover untuk ${post.data.title}`} 
            class="post-cover"
          />
        )}
      </div>
    </a>
  ))}
</div>
  </main>
</Base>

<style>
  main { padding: 3rem 2rem; max-width: 900px; margin: 0 auto; } /* Sedikit diperlebar */

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border); /* Garis sedikit lebih tegas */
    margin-bottom: 2rem;
  }
  .page-header h2 {
    font-size: 14px; /* Diperbesar sedikit */
    font-family: system-ui;
    color: var(--muted);
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .page-header p { font-size: 12px; color: var(--muted); }

  .categories {
    display: flex;
    gap: .75rem;
    margin-bottom: 2rem; /* Dikurangi jaraknya */
    flex-wrap: wrap;
  }
  .cat {
    font-size: 13px;
    color: var(--muted);
    padding: 6px 14px;
    border: 1px solid var(--border);
    cursor: pointer;
    border-radius: 2px; /* Sedikit lengkung ala tombol modern */
  }
  .cat.active { color: var(--text); border-color: var(--text); background: rgba(255,255,255,0.05); }

  .post-list { display: flex; flex-direction: column; }

  .post-item {
    display: grid;
    /* UPDATE GRID: Kolom gambar diperbesar jadi 160px */
    grid-template-columns: 40px 1fr 160px; 
    align-items: start; /* Supaya rata atas, bukan tengah */
    gap: 2rem;
    padding: 2.5rem 0; /* Padding diperbesar agar lega */
    border-bottom: 1px solid var(--border);
    transition: background-color .2s;
    text-decoration: none;
  }
  .post-item:first-child { border-top: 1px solid var(--border); }
  
  /* Efek hover yang lebih elegan, bukan opacity */
  .post-item:hover .post-title { color: #888; } 

  .post-number {
    font-size: 14px;
    color: var(--muted);
    font-family: monospace;
    font-weight: bold;
    margin-top: 4px; /* Menyelaraskan dengan tinggi font judul */
  }
  
  .post-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem; /* Jarak teratur antar judul, deskripsi, meta */
  }

  .post-title {
    font-family: Georgia, serif;
    font-size: 24px; /* SIKAT! Judul jauh lebih besar */
    font-weight: 700; /* Ditebalkan */
    line-height: 1.2;
    color: var(--text);
    margin: 0;
    transition: color 0.2s;
  }
  
  /* GAYA BARU UNTUK DESKRIPSI */
  .post-excerpt {
    font-size: 15px;
    line-height: 1.5;
    color: #999; /* Abu-abu agak terang */
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2; /* Maksimal 2 baris lalu titik-titik */
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta { font-size: 13px; color: var(--muted); margin: 0; margin-top: 0.2rem; }
  .post-meta .separator { margin: 0 6px; color: #555; }

  .post-cover-container {
    display: flex;
    justify-content: flex-end;
  }
  
  /* UPDATE GAMBAR: Jadi persegi panjang ala Medium */
  .post-cover {
    width: 160px;
    height: 106px; /* Rasio 3:2 */
    object-fit: cover;
    border: 1px solid var(--border);
    background-color: #111; /* Placeholder kalau gambar loading */
  }

  /* --- MEDIA QUERY UNTUK LAYAR HP --- */
  @media (max-width: 640px) {
    main { padding: 2rem 1.25rem; }
    
    .page-header { flex-direction: column; gap: 0.5rem; border-bottom: none; padding-bottom: 0; }

    .categories {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.5rem; 
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .categories::-webkit-scrollbar { display: none; }
    .cat { white-space: nowrap; }

    .post-item {
      /* Di HP, gambar kembali kotak kecil agar hemat ruang */
      grid-template-columns: 28px 1fr 64px; 
      gap: 1rem;
      padding: 1.5rem 0;
    }

    .post-cover {
      width: 64px;
      height: 64px;
    }

    .post-title { font-size: 18px; }
    
    .post-excerpt {
      font-size: 13px;
      -webkit-line-clamp: 2; /* Maksimal 2 baris di HP */
    }
  }
</style>