---
import Base from '../layouts/Base.astro'
---
<Base title="Afif Musyaffa">
  <main>
    <div class="hero-left">
      <p class="eyebrow">Jakarta — Content Creator</p>
      <h1>Afif<br>Musyaffa.</h1>
      <p class="bio">Videographer, photographer, and writer based in Jakarta. I document what's worth remembering.</p>
      <div class="cta">
        <a href="/work">See my work →</a>
        <a href="/writing" class="secondary">Read my writing</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="featured-work">
        <span class="placeholder-label">Featured work</span>
      </div>
      <div class="latest-writing">
        <div>
          <p class="writing-label">Latest writing</p>
          <p class="writing-title">Judul artikel terbaru kamu</p>
        </div>
        <span>→</span>
      </div>
    </div>
  </main>
</Base>

<style>
  main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: calc(100vh - 57px);
  }
  .hero-left {
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 0.5px solid var(--border);
  }
  .eyebrow {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  h1 { font-size: 52px; line-height: 1.0; margin-top: 2rem; }
  .bio {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
    max-width: 300px;
    margin-top: 1.75rem;
  }
  .cta {
    display: flex;
    gap: 1.5rem;
    padding-top: 1.25rem;
    border-top: 0.5px solid var(--border);
  }
  .cta a { font-size: 12px; border-bottom: 1px solid var(--border); padding-bottom: 2px; }
  .cta a.secondary { color: var(--muted); border-bottom: none; }
  .hero-right { display: grid; grid-template-rows: 1fr auto; }
  .featured-work {
    background: var(--surface);
    border-bottom: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .latest-writing {
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .latest-writing > div { flex: 1; }
  .writing-label {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .writing-title { font-size: 13px; margin-top: .3rem; line-height: 1.4; }
  .placeholder-label { font-size: 11px; color: var(--muted); }
</style>