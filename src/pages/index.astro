---
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Afif Musyaffa</title>
  </head>
  <body>
    <nav>
      <span class="logo">afif</span>
      <div class="nav-links">
        <a href="/work">Work</a>
        <a href="/writing">Writing</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <main>
      <div class="hero-left">
        <p class="eyebrow">Jakarta — Content Creator</p>
        <h1>Afif<br>Musyaffa.</h1>
        <p class="bio">Videographer, photographer, and writer based in Jakarta. I document what's worth remembering.</p>
        <div class="cta">
          <a href="/work">See my work →</a>
          <a href="/writing" class="secondary">Read my writing</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="featured-work">
          <span class="placeholder-label">Featured work</span>
        </div>
        <div class="latest-writing">
          <p class="writing-label">Latest writing</p>
          <p class="writing-title">Judul artikel terbaru kamu</p>
          <span>→</span>
        </div>
      </div>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a0a0a;
    --surface: #141414;
    --text: #f0ece4;
    --muted: #888780;
    --accent: #000072;
    --border: rgba(240, 236, 228, 0.1);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.7;
  }
  h1, h2, h3 {
    font-family: Georgia, serif;
    font-weight: 400;
  }
  a { color: inherit; text-decoration: none; }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    border-bottom: 0.5px solid var(--border);
  }
  .logo { font-size: 13px; font-weight: 500; }
  .nav-links { display: flex; gap: 1.5rem; }
  .nav-links a { font-size: 12px; color: var(--muted); }
  .nav-links a:hover { color: var(--text); }

  main {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: calc(100vh - 57px);
  }

  .hero-left {
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-right: 0.5px solid var(--border);
  }
  .eyebrow {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  h1 {
    font-size: 52px;
    line-height: 1.0;
    margin-top: 2rem;
  }
  .bio {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
    max-width: 300px;
    margin-top: 1.75rem;
  }
  .cta {
    display: flex;
    gap: 1.5rem;
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 0.5px solid var(--border);
  }
  .cta a { font-size: 12px; color: var(--text); border-bottom: 1px solid var(--border); padding-bottom: 2px; }
  .cta a.secondary { color: var(--muted); border-bottom: none; }
  .cta a:hover { color: var(--text); }

  .hero-right {
    display: grid;
    grid-template-rows: 1fr auto;
  }
  .featured-work {
    background: var(--surface);
    border-bottom: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .placeholder-label {
    font-size: 11px;
    color: var(--muted);
  }
  .latest-writing {
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .latest-writing > div { flex: 1; }
  .writing-label {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .writing-title {
    font-size: 13px;
    color: var(--text);
    line-height: 1.4;
    margin-top: .3rem;
  }
</style>