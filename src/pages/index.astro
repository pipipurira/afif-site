---
import Base from '../layouts/Base.astro'
import { getCollection } from 'astro:content'

// Kita hanya membutuhkan data tulisan terbaru untuk Hero Section.
// Logika pengambilan data projek (Work Grid) telah dihapus total.
const allPosts = await getCollection('writing')
const recentPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3)
---

<Base title="Afif Musyaffa">
  <main>

    <section class="hero-giant-typography">
      <h1>
        <span class="line">WELCOME TO THE</span>
        <span class="line">EVERYDAY MESS</span>
        <span class="line">INSIDE MY HEAD.</span>
      </h1>
      
      <p class="hero-subtitle">
        <span class="line">MAKING HONEST</span>
        <span class="line">THINGS & LETTING</span>
        <span class="line">THE NOISE FIND</span>
        <span class="line">ITS PEOPLE.</span>
      </p>
    </section>
    <section class="section-work-showreel">
      
 
      <a href="/work" class="work-marquee-banner">
        <div class="marquee-track">
          <img src="https://picsum.photos/id/447/800/1000.webp" alt="Projek 1" />
          <img src="https://picsum.photos/id/448/800/1000.webp" alt="Projek 2" />
          <img src="https://picsum.photos/id/449/800/1000.webp" alt="Projek 3" />
          <img src="https://picsum.photos/id/450/800/1000.webp" alt="Projek 4" />
          
          <img src="https://picsum.photos/id/447/800/1000.webp" alt="Projek 1" />
          <img src="https://picsum.photos/id/448/800/1000.webp" alt="Projek 2" />
          <img src="https://picsum.photos/id/449/800/1000.webp" alt="Projek 3" />
          <img src="https://picsum.photos/id/450/800/1000.webp" alt="Projek 4" />
        </div>

        <div class="banner-overlay">
          <span class="view-all-label">Lihat Semua Projek — Click Here</span>
        </div>
      </a>
    </section>

    <section class="section-writing">
      <div class="section-header">
        <p class="section-label">Writing</p>
        <a href="/writing" class="section-link">Lihat semua →</a>
      </div>
      <div class="post-list">
        {recentPosts.map((post, i) => (
          <a href={`/writing/${post.id}`} class="post-item-medium">
            <div class="post-content-area">
              <div class="post-meta-top">
                <span class="post-category-tag">{post.data.category}</span>
                <span class="post-author">oleh Afif Musyaffa</span>
              </div>
              
              <h3 class="post-title-medium">{post.data.title}</h3>
              
              
              {post.data.description && (
                <p class="post-excerpt">{post.data.description}</p>
              )}
              
              <div class="post-meta-bottom">
                <span>{post.data.date.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                <span class="read-time">· 3 min read</span>
              </div>
            </div>

            {post.data.cover ? (
              <div class="post-thumbnail-area">
                <img src={post.data.cover} alt={`Cover untuk ${post.data.title}`} />
              </div>
            ) : (
              <div class="post-thumbnail-placeholder"></div>
            )}
          </a>
        ))}
        {recentPosts.length === 0 && (
          <p class="empty">Belum ada tulisan.</p>
        )}
      </div>
    </section>

  </main>
</Base>

<style>
  /* --- Global Styles --- */
  main {
    max-width: 1440px; 
    margin: 0 auto;
  }

  /* --- HERO GIANT TYPOGRAPHY --- */
  .hero-giant-typography {
    padding: 4rem 0 0 0; 
    display: flex;
    flex-direction: column;
  }

  .hero-giant-typography h1 {
    font-family: 'Helvetica Neue', Arial, sans-serif; 
    font-size: 8.5vw; /* Ukuran yang pas untuk teks panjang */
    font-weight: 900; 
    line-height: 0.85; 
    text-transform: uppercase; 
    letter-spacing: -0.03em; 
    color: var(--text);
    margin: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hero-giant-typography .line {
    display: block;
    white-space: nowrap;
  }
  /* --- SUBTITLE (HIERARKI LEBIH KECIL) --- */
  .hero-subtitle {
    font-family: 'Helvetica Neue', Arial, sans-serif; 
    font-size: 3.5vw; /* Ukuran menyusut jauh dibanding H1 (8.5vw) */
    font-weight: 700; /* Tetap tebal, tapi tidak segemuk H1 */
    line-height: 1; /* Jarak antar baris sedikit dilonggarkan */
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--text); /* Opsional: Jika ingin lebih kalem, ubah jadi var(--muted) */
    margin: 0; /* Memberikan jarak pemisah dari teks raksasa di atasnya */
    
    display: flex;
    flex-direction: column;
  }

  

  /* Penyesuaian jarak Showreel */
  /* Penyesuaian jarak Showreel & Breakout Edge-to-Edge */
  .section-work-showreel {
    margin-top: 0; 
    padding-bottom: 0; 
    margin-bottom: 4rem; 
    
    /* TRIK BREAKOUT */
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden; 
    
    border: none; 
  }

  /* Responsivitas HP */
  @media (max-width: 640px) {
    .hero-giant-typography {
      padding-top: 2rem;
      padding-left: 1rem; 
      padding-right: 1rem;
    }
    
    .hero-giant-typography h1 {
      font-size: 9.5vw; 
      line-height: 0.85;
    }
    
    .hero-subtitle {
      font-size: 5vw; 
      margin-top: 0; 
    }
  }

  .writing-title { font-size: 13px; margin-top: .3rem; line-height: 1.4; }
  /* --- Section Shared --- */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }
  .section-label {
    font-size: 14px; /* Naik dari 11px */
    color: var(--muted);
    letter-spacing: .1em;
    text-transform: uppercase;
  }
  .section-link { font-size: 12px; color: var(--muted); }
  .section-link:hover { color: var(--text); }

/* --- Work Section (Marquee Showreel) --- */

  .work-marquee-banner {
    width: 100%;
    height: 50vh; /* Tinggi banner di desktop mengambil 50% tinggi layar */
    background: var(--bg);
    border: 0.5px solid var(--border);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    cursor: pointer;
  }
  
  .marquee-track {
    display: flex;
    height: 100%;
    width: max-content;
    animation: scrollMarquee 20s linear infinite; 
  }

  .marquee-track img {
    height: 100%;
    width: 25vw;
    object-fit: cover;
    /* --- PERUBAHAN 1: DEFAULT BERWARNA --- */
    filter: grayscale(0%) blur(0px); /* Pastikan tajam dan berwarna */
    border-right: 0.5px solid var(--border);
    transition: filter 0.3s ease; /* Transisi halus untuk blur */
  }

  /* --- PERUBAHAN 2: HOVER ADD BLUR (Bukan menghapus grayscale) --- */
  /* Efek blur diaplikasikan pada gambar saat banner di-hover */
  .work-marquee-banner:hover .marquee-track img { 
    filter: grayscale(0%) blur(4px); /* Blur 4px untuk kontras */
  }

  @keyframes scrollMarquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); } 
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0); /* Transparan penuh di desktop saat normal */
    transition: background-color 0.3s;
    z-index: 2;
  }

  /* --- PERUBAHAN 3: DARKEN OVERLAY SAAT HOVER --- */
  /* Sedikit gelapkan background di atas gambar yang blur agar teks putih makin menonjol */
  .work-marquee-banner:hover .banner-overlay {
    background: rgba(0,0,0,0.4); 
  }

  .view-all-label {
    padding: 10px 20px;
    border: 0.5px solid white;
    background: rgba(0,0,0,0.7);
    color: white;
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0; /* Tersembunyi di desktop saat normal */
    transition: opacity 0.3s;
  }
  
  .work-marquee-banner:hover .view-all-label {
    opacity: 1; /* Muncul saat hover di desktop */
  }

  /* --- Writing Section --- */
  .section-writing {
    padding: 4rem 2rem;
    background: var(--bg);
    border-bottom: 0.5px solid var(--border);
  }
  
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 3rem; 
    width: 100%; 
  }

  .post-item-medium {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 0.5px solid var(--border);
    transition: opacity .2s;
  }
  .post-item-medium:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .post-item-medium:hover { opacity: .7; }

.post-item-medium img {
    width: 320px;
    height: 200px;
    object-fit: cover;
  }
  /* Area Teks Kiri */
  .post-content-area {
    flex: 1; /* Mengambil sisa ruang */
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-meta-top {
    font-size: 13px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .post-category-tag {
    background: var(--surface);
    padding: 2px 8px;
    border-radius: 4px; /* Sedikit melengkung ala Medium */
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
    border: 0.5px solid var(--border);
  }
  .post-author { color: var(--muted); }

  .post-title-medium {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; /* Medium menggunakan sans-serif tebal untuk judul */
    font-size: 28px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--text);
    margin: 0;
  }

  .post-excerpt {
    font-family: Georgia, serif;
    font-size: 16px;
    line-height: 1.5;
    color: var(--muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2; /* Batasi maksimal 2 baris teks */
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta-bottom {
    font-size: 13px;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  /* Area Gambar Kanan */
  .post-thumbnail-area {
    width: 200px; /* Lebar gambar tetap ala Medium */
    height: 134px; /* Rasio 3:2 */
    flex-shrink: 0; /* Mencegah gambar tergencet */
    background: var(--surface);
    overflow: hidden;
  }
  
  .post-thumbnail-area img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    
    /* --- PERUBAHAN 1: HAPUS GRAYSCALE, TAMBAH WARNA --- */
    filter: grayscale(0%); /* Gambar selalu berwarna penuh */
    opacity: 1; /* Terang penuh saat normal */
    
    /* Gunakan transisi untuk efek redup yang halus */
    transition: opacity 0.3s ease; 
  }

  /* --- PERUBAHAN 2: HOVER MEMBUAT REDUP (DIM) --- */
  /* Saat item tulisan di-hover, gambarnya redup menjadi 70% kecerahan */
  .post-item-medium:hover .post-thumbnail-area img {
    filter: grayscale(0%); /* Tetap berwarna */
    opacity: 0.7; /* Menjadi sedikit redup untuk kontras */
  }

  .post-thumbnail-placeholder {
    display: none; /* Sembunyikan jika tidak ada gambar */
  }

  /* --- Penyesuaian Media Query untuk Mobile --- */
  @media (max-width: 768px) {
    .post-item-medium {
      flex-direction: column-reverse; /* Di HP, gambar di atas teks */
      align-items: flex-start;
      gap: 1.5rem;
      padding-bottom: 2.5rem;
    }
    .post-thumbnail-area {
      width: 100%; /* Gambar penuh di HP */
      height: 200px;
    }
    .post-title-medium {
      font-size: 22px;
    }
    .post-list { gap: 2.5rem; }
  }

  .placeholder-label { font-size: 11px; color: var(--muted); }
  .empty { font-size: 13px; color: var(--muted); }

  /* --- MEDIA QUERIES (Untuk Layar HP < 768px) --- */
  @media (max-width: 768px) {
    /* Penyesuaian Hero Inside Head di HP */
    .hero-inside-head {
      min-height: 70vh; /* Sedikit lebih pendek di HP agar Showreel di bawahnya bisa sedikit mengintip */
      padding: 1rem;
    }

    /* Penyesuaian Khusus Marquee di HP agar tampil sempurna */
    .work-marquee-banner {
      height: auto; /* Menggunakan rasio aspek, bukan tinggi tetap */
      aspect-ratio: 4/5; /* Menjadi potret agar menonjol di layar HP */
    }
    .marquee-track {
      animation-duration: 12s; /* Di HP, animasinya dipercepat agar terasa dinamis */
    }
    .marquee-track img {
      width: 65vw;
      /* --- PERUBAHAN DI MOBILE: JAGA TETAP TAJAM & BERWARNA --- */
      filter: grayscale(0%) blur(0px) !important; /* Nonaktifkan blur di HP */
    }

    /* Penyesuaian Overlay Label di HP */
    .view-all-label {
      opacity: 1; /* Selalu muncul di HP */
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(4px);
      padding: 8px 16px;
    }

    /* Penyesuaian Writing List di HP */
    .post-item {
      grid-template-columns: 32px 1fr auto;
      gap: 1rem;
    }
    .post-title { font-size: 16px; }
  }
</style>