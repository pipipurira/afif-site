---
import Base from '../layouts/Base.astro'
import { getCollection } from 'astro:content'

const projects = await getCollection('work')
const featured = projects.find(p => p.data.featured)
const rest = projects.filter(p => !p.data.featured)
---

<Base title="Work">
  <main>
    <div class="page-header">
      <h2>Work</h2>
      <p>Foto & video — {projects.length} projects</p>
    </div>

    {featured && (
      <a href={`/work/${featured.id}`} class="featured">
        <div class="featured-thumb" style={featured.data.thumbnail ? `background-image: url(${featured.data.thumbnail}); background-size: cover; background-position: center;` : ''}>
          {!featured.data.thumbnail && <span class="placeholder-label">Featured</span>}
        </div>
        <div class="featured-info">
          <div>
            <span class="tag">{featured.data.category}</span>
            <h1>{featured.data.title}</h1>
          </div>
          <div class="featured-meta">
            <span>{featured.data.year}</span>
            <span>Lihat project →</span>
          </div>
        </div>
      </a>
    )}

    {!featured && projects.length === 0 && (
      <p class="empty">Belum ada project.</p>
    )}

    {rest.length > 0 && (
      <div class="grid">
        {rest.map(project => (
          <a href={`/work/${project.id}`} class="project-card">
            <div class="card-thumb" style={project.data.thumbnail ? `background-image: url(${project.data.thumbnail}); background-size: cover; background-position: center;` : ''}>
              {!project.data.thumbnail && <span class="placeholder-label">{project.data.category}</span>}
            </div>
            <div class="card-info">
              <p class="card-title">{project.data.title}</p>
              <p class="card-meta">{project.data.category} · {project.data.year}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</Base>

<style>
  main { padding: 3rem 2rem; max-width: 1200px; margin: 0 auto; }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 3rem;
  }
  .page-header h2 { font-size: 13px; font-family: system-ui; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; }
  .page-header p { font-size: 12px; color: var(--muted); }

  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 0.5px solid var(--border);
    margin-bottom: 3rem;
    min-height: 400px;
  }
  .featured:hover .featured-thumb { opacity: .85; }
  .featured-thumb {
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity .2s;
  }
  .featured-info {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-left: 0.5px solid var(--border);
  }
  .tag {
    display: inline-block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding: 3px 10px;
    border: 0.5px solid var(--border);
  }
  .featured-info h1 { font-size: 36px; line-height: 1.1; }
  .featured-meta {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
    padding-top: 1.5rem;
    border-top: 0.5px solid var(--border);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 0.5px solid var(--border);
  }
  .project-card {
    background: var(--bg);
    display: flex;
    flex-direction: column;
  }
  .project-card:hover .card-thumb { opacity: .8; }
  .card-thumb {
    aspect-ratio: 16/9;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity .2s;
  }
  .card-info {
    padding: 1.25rem;
    border-top: 0.5px solid var(--border);
  }
  .card-title { font-size: 14px; }
  .card-meta { font-size: 12px; color: var(--muted); margin-top: .3rem; }
  .placeholder-label { font-size: 11px; color: var(--muted); }
  .empty { font-size: 13px; color: var(--muted); }
</style>