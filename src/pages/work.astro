---
import Base from '../layouts/Base.astro'

const projects = [
  {
    slug: "project-1",
    title: "Judul Project Pertama",
    category: "Videografi",
    year: "2024",
    featured: true,
  },
  {
    slug: "project-2",
    title: "Judul Project Kedua",
    category: "Fotografi",
    year: "2024",
    featured: false,
  },
  {
    slug: "project-3",
    title: "Judul Project Ketiga",
    category: "Videografi",
    year: "2023",
    featured: false,
  },
  {
    slug: "project-4",
    title: "Judul Project Keempat",
    category: "Fotografi",
    year: "2023",
    featured: false,
  },
]

const featured = projects.find(p => p.featured)
const rest = projects.filter(p => !p.featured)
---

<Base title="Work">
  <main>
    <div class="page-header">
      <h2>Work</h2>
      <p>Foto & video — {projects.length} projects</p>
    </div>

    {featured && (
      <a href={`/work/${featured.slug}`} class="featured">
        <div class="featured-thumb">
          <span class="placeholder-label">Featured</span>
        </div>
        <div class="featured-info">
          <div>
            <span class="tag">{featured.category}</span>
            <h1>{featured.title}</h1>
          </div>
          <div class="featured-meta">
            <span>{featured.year}</span>
            <span>Lihat project →</span>
          </div>
        </div>
      </a>
    )}

    <div class="grid">
      {rest.map(project => (
        <a href={`/work/${project.slug}`} class="project-card">
          <div class="card-thumb">
            <span class="placeholder-label">{project.category}</span>
          </div>
          <div class="card-info">
            <p class="card-title">{project.title}</p>
            <p class="card-meta">{project.category} · {project.year}</p>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  main { padding: 3rem 2rem; max-width: 1200px; margin: 0 auto; }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 3rem;
  }
  .page-header h2 { font-size: 13px; font-family: system-ui; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; }
  .page-header p { font-size: 12px; color: var(--muted); }

  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 0.5px solid var(--border);
    margin-bottom: 3rem;
    min-height: 400px;
  }
  .featured:hover .featured-thumb { opacity: .85; }
  .featured-thumb {
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity .2s;
  }
  .featured-info {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-left: 0.5px solid var(--border);
  }
  .tag {
    display: inline-block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    padding: 3px 10px;
    border: 0.5px solid var(--border);
  }
  .featured-info h1 { font-size: 36px; line-height: 1.1; }
  .featured-meta {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
    padding-top: 1.5rem;
    border-top: 0.5px solid var(--border);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 0.5px solid var(--border);
  }
  .project-card {
    background: var(--bg);
    display: flex;
    flex-direction: column;
  }
  .project-card:hover .card-thumb { opacity: .8; }
  .card-thumb {
    aspect-ratio: 16/9;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity .2s;
  }
  .card-info {
    padding: 1.25rem;
    border-top: 0.5px solid var(--border);
  }
  .card-title { font-size: 14px; }
  .card-meta { font-size: 12px; color: var(--muted); margin-top: .3rem; }
  .placeholder-label { font-size: 11px; color: var(--muted); }
</style>