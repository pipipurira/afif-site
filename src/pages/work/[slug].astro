---
import Base from '../../layouts/Base.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const projects = await getCollection('work')
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }))
}

const { project } = Astro.props
const { Content } = await render(project)
---

<Base title={project.data.title}>
  <article>
    {project.data.thumbnail && (
      <div class="cover">
        <img src={project.data.thumbnail} alt={project.data.title} />
      </div>
    )}
    <div class="content">
      <div class="meta">
        <span class="category">{project.data.category}</span>
        <span class="year">{project.data.year}</span>
      </div>
      <h1>{project.data.title}</h1>
      <div class="body">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  article { max-width: 720px; margin: 0 auto; padding: 3rem 2rem; }

  .cover {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  .cover img { width: 100%; height: 100%; object-fit: cover; }

  .meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .category {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: .08em;
    text-transform: uppercase;
    border: 0.5px solid var(--border);
    padding: 3px 10px;
  }
  .year { font-size: 12px; color: var(--muted); align-self: center; }

  h1 {
    font-family: Georgia, serif;
    font-size: 36px;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--border);
  }

  .body { font-family: Georgia, serif; font-size: 18px; line-height: 1.8; }
  .body p { margin-bottom: 1.5rem; }
</style>